{
  "name": "ondc-metro-qr-generator",
  "version": "0.0.1",
  "description": "Typed ONDC metro QR payload and PNG generation for supported BPP policies.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.1.43",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "typescript": "^5.9.3",
    "zxing-wasm": "^3.1.0"
  }
}
