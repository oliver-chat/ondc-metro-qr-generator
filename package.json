{
  "name": "ondc-metro-qr-generator",
  "version": "0.0.4",
  "description": "Typed ONDC metro QR payload and PNG generation for supported BPP policies.",
  "license": "Apache-2.0",
  "author": "Oliver Chat",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oliver-chat/ondc-metro-qr-generator.git"
  },
  "type": "module",
  "packageManager": "bun@1.1.43",
  "sideEffects": false,
  "files": [
    "dist",
    "docs/provider-policies",
    "CONTRIBUTING.md",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "check": "bun run lint && bun run typecheck && bun test && bun run build && bun run check:package",
    "check:package": "publint && attw --pack . --profile esm-only",
    "format": "biome format --write .",
    "lint": "biome check .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "pack:dry-run": "npm pack --dry-run"
  },
  "dependencies": {
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@biomejs/biome": "^2.3.8",
    "@types/bun": "^1.3.14",
    "@types/qrcode": "^1.5.6",
    "publint": "^0.3.21",
    "typescript": "^5.9.3",
    "zxing-wasm": "^3.1.0"
  }
}
